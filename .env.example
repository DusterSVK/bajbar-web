# ── Kontaktný formulár (Resend) ─────────────────────────────────────────────
# Bez RESEND_API_KEY formulár funguje v "dev" režime (dopyt sa len zaloguje).
RESEND_API_KEY=
# Kam chodia dopyty (default: contact.email z lib/config.ts).
LEAD_TO_EMAIL=
# Overený odosielateľ v Resend (default: web@<doména>).
LEAD_FROM_EMAIL=

# ── Google Analytics 4 (voliteľné) ──────────────────────────────────────────
# Načíta sa AŽ po udelení cookie súhlasu. Bez ID sa GA nenačíta.
NEXT_PUBLIC_GA_ID=

# Pozn.: Doména/canonical (site.url) sa nastavuje v lib/config.ts, nie tu.
